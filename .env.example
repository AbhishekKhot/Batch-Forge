# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5434/batchforge
DB_USERNAME=batchforge
DB_PASSWORD=change-me
DB_POOL_MAX=12
DB_POOL_MIN_IDLE=4

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=batchforge
RABBITMQ_PASSWORD=change-me

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change-me

# ── JWT ─────────────────────────────────────────────────────────────────────
BATCHFORGE_JWT_SECRET=change-me-to-a-long-random-production-secret

# ── MinIO / object storage ──────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=batchforge
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=batchforge

# ── Profile ─────────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=prod